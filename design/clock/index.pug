doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(http-equiv="X-UA-Compatible", content="IE=edge")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title World Clock
    link(
        rel="stylesheet",
        href="https://pro.fontawesome.com/releases/v5.10.0/css/all.css",
        integrity="sha384-AYmEC3Yw5cVb3ZcuHtOA93w35dYTsvhLPVnYs9eStHfGJvOvKxVfELGroGkvsg+p",
        crossorigin="anonymous"
    )
  body
    .wrap
        .header
            h1.title World Clock
        .main
            .clock-outer-fram
                .clock-outer
                    .clock
                        .point-icon-outer
                            i.fas.fa-compact-disc.point-icon
                        - 
                            clockRomeNum = [
                                'XII','I','II',
                                'III','IV','V',
                                'VI','VII','VIII',
                                'IX','X','XI'
                            ]
                        each str in clockRomeNum
                            .num #{str}
                        - time = ['seconds', 'minute', 'hour']
                        each str in time
                            .line(class=[str])
            .show-text-group
                span.city-show
                span.time-show-day
                span.time-show
            .select-group
            .loading-outer
                .loading
                    svg.fsg(width="100%", height="100%")
                        defs
                            linearGradient#a1(x1="0%", y1="0%", x2="100%", y2="100%")
                                stop(offset="10%", stop-color="rgb(0,162,250)")
                                stop(offset="50%", stop-color="rgb(0,90,250)", stop-opacity=".5")
                                stop(offset="70%", stop-color="rgb(0,0,0)", stop-opacity="0")
                                stop(offset="90%", stop-color="rgb(0,0,0)", stop-opacity="0")
                                stop(offset="100%", stop-color="rgb(0,0,0)", stop-opacity="0")
                        circle(cx="100", cy="100", r="80", stroke-width="6", stroke="url(#a1)", fill="none")
                    .loading-text Loading
        .footer
            h6 CopyRight &copy; 2020-05 Alex Chen
    script(type="module", src="./index.ts")